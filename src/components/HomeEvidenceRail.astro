---
import type { CaseProject } from "@/data/projects";

interface Props {
  projects: CaseProject[];
}

const { projects } = Astro.props;
const formatter = new Intl.DateTimeFormat("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit" });
const formatDate = (value: string) => formatter.format(new Date(`${value}T00:00:00+08:00`));
const items = projects
  .filter((project) => project.featured)
  .flatMap((project) => {
    const evidence = project.evidence.find((evidence) => evidence.href);
    return evidence?.href ? [{ project, evidence, href: evidence.href }] : [];
  });
---

<aside class="home-evidence-rail" aria-label="最近核验证据">
  <header>
    <span>最近核验证据</span>
    <small>可直接打开</small>
  </header>
  <div class="home-evidence-items">
    {items.map(({ project, evidence, href }) => (
      <a class="home-evidence-link" href={href}>
        <span class="home-evidence-project">{project.name}</span>
        <strong>{evidence.label}</strong>
        <time datetime={evidence.verifiedAt}>{formatDate(evidence.verifiedAt)}</time>
        <span class="home-evidence-open" aria-hidden="true">打开 ↗</span>
      </a>
    ))}
  </div>
</aside>
